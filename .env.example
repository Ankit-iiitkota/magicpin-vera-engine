# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=vera-engine
TEAM_NAME="Team Vera"
ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
RELOAD=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_FALLBACK_TO_MEMORY=true
REDIS_CONNECT_TIMEOUT=3

# ── LLM (future use — judge_simulator.py uses this, not Vera itself) ──────────
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FORMAT=json      # json | console  (default: json)

# ── Weights ───────────────────────────────────────────────────────────────────
WEIGHTS_FILE=config/weights.yaml

# ── Startup Validation ────────────────────────────────────────────────────────
STARTUP_VALIDATION_ENABLED=true
STARTUP_VALIDATION_FAIL_FAST=true
